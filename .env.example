# Google Gemini Configuration (FREE - recommended to start)
# Get your FREE API key from: https://aistudio.google.com/app/apikey
# No credit card needed! Currently active by default.
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI Configuration (PAID - backup option)
# Get your API key from: https://platform.openai.com/api-keys
# To use OpenAI instead: rename route-openai.ts.backup to route.ts
OPENAI_API_KEY=sk-proj-your-key-here

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/efrise?retryWrites=true&w=majority

# Email Configuration (Phase 2 - Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password
NOTIFICATION_EMAIL=oscar@efrisedigital.com

# App Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
